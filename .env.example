# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Amazon Product Advertising API (PA-API 5.0) — server-side only
AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key
AMAZON_AFFILIATE_TAG=your_affiliate_tag-21
AMAZON_MARKETPLACE=it

# AliExpress Affiliate API — server-side only
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_app_secret
ALIEXPRESS_TRACKING_ID=your_tracking_id
